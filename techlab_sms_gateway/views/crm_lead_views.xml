<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Inherit CRM Lead Form View -->
    <record id="view_crm_lead_form_sms" model="ir.ui.view">
        <field name="name">crm.lead.form.sms</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_lead_view_form"/>
        <field name="arch" type="xml">
            <div name="button_box" position="inside">
                <button name="action_send_sms" type="object" class="oe_stat_button" icon="fa-commenting">
                    <div class="o_field_widget o_stat_info">
                        <span class="o_stat_text">Send</span>
                        <span class="o_stat_text">SMS</span>
                    </div>
                </button>
            </div>
        </field>
    </record>
</odoo>